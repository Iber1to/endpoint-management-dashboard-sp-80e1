POSTGRES_DB=endpoint_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=replace_with_dev_password
DATABASE_URL=postgresql+psycopg://dashboard:replace_with_dev_password@postgres:5432/endpoint_dashboard

APP_ENV=development
APP_SECRET_KEY=replace_with_dev_secret_min_32_chars
ENCRYPTION_KEY=replace_with_generated_fernet_key
DEFAULT_TIMEZONE=Europe/Madrid

BACKEND_PORT=8000
FRONTEND_PORT=3000

PATCH_CATALOG_SYNC_INTERVAL_MINUTES=1440
INVENTORY_SYNC_INTERVAL_MINUTES=1440
SCHEDULER_ENABLED=true
SCHEDULER_LOCK_KEY=81317077

ADMIN_API_KEY=admin-test-key
OPERATOR_API_KEY=operator-test-key
READONLY_API_KEY=read-test-key
