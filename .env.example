POSTGRES_DB=endpoint_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql+psycopg://dashboard:changeme_secure_password@postgres:5432/endpoint_dashboard

APP_ENV=production
APP_SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars
ENCRYPTION_KEY=change_this_to_a_32_byte_fernet_key_base64_encoded=
DEFAULT_TIMEZONE=Europe/Madrid

BACKEND_PORT=8000
FRONTEND_PORT=3000

PATCH_CATALOG_SYNC_INTERVAL_MINUTES=1440
INVENTORY_SYNC_INTERVAL_MINUTES=60
